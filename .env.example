# Database (required for API)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# LINE Login (required for LINE login)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CALLBACK_URL=https://6542d57d-f8ce-404c-adb7-16f6dc84b252-00-1ncerp2gwoflp.spock.replit.dev/api/auth/line-callback
FRONTEND_URL=https://your-app.vercel.app

# JWT (required in production)
SESSION_SECRET=your-random-secret-at-least-32-chars

# Frontend: API base URL (set in Vercel for static build). 同一オリジン（フロント・API同一Vercelプロジェクト）の場合は Vercel のドメインを指定（例: https://your-app.vercel.app）
EXPO_PUBLIC_DOMAIN=https://your-app.vercel.app

# Optional: Stripe
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# 通報のClaude API自動判定（未設定時はグレーゾーンとして管理者確認に回す）
# ANTHROPIC_API_KEY=

# Templated.io（AI Edit の MP4 レンダー）。未設定時は POST /api/ai-edit/jobs/:id/render は 503
TEMPLATED_API_KEY=c127edfe-8396-4c31-be3a-59ced46e2920

# 任意: Templated の webhook が叩く公開 API のオリジン（末尾スラッシュなし）。未設定時は FRONTEND_URL または rawstock.live
# TEMPLATED_WEBHOOK_BASE_URL=https://your-api.example.com
