# ============================================================
# Database (required)
# ============================================================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================================
# Auth (required)
# ============================================================
SESSION_SECRET=your-random-secret-at-least-32-chars

# Google OAuth (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# Domain (required)
# ============================================================
# Production frontend URL (used for OAuth redirect, Stripe success URL, etc.)
FRONTEND_URL=https://rawstock.live

# Frontend API base URL (used by Expo app to reach the backend)
EXPO_PUBLIC_DOMAIN=https://rawstock.live

# ============================================================
# DeepAR Web (optional — live broadcast background blur)
# ============================================================
# https://developer.deepar.ai — domain must match your web app.
# After npm install, postinstall copies wasm/effects into public/deepar/ (gitignored).
# EXPO_PUBLIC_DEEPAR_KEY=

# ============================================================
# Cloudflare Stream (required for live streaming)
# ============================================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=

# ============================================================
# Cloudflare R2 (required for file uploads)
# ============================================================
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=

# ============================================================
# Upstash Redis (required for caching / rate limiting)
# ============================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# Stripe (required for payments)
# ============================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ============================================================
# YouTube API (required for YouTube search)
# ============================================================
YOUTUBE_API_KEY=

# ============================================================
# Anthropic Claude API (optional)
# Used for AI moderation of reports. If unset, reports go to gray zone for manual review.
# ============================================================
# ANTHROPIC_API_KEY=

# ============================================================
# Templated.io (optional — required for AI Edit MP4 rendering)
# If unset, POST /api/ai-edit/jobs/:id/render returns 503
# ============================================================
TEMPLATED_API_KEY=

# Override the public API origin that Templated webhook calls back to.
# Defaults to FRONTEND_URL or rawstock.live if unset.
# TEMPLATED_WEBHOOK_BASE_URL=https://your-api.example.com

# ============================================================
# Admin (optional)
# ============================================================
# Email address of the site admin (used for certain admin-only features)
# ADMIN_EMAIL=
