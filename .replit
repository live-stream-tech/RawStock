entrypoint = "README.md"
modules = ["nodejs-22", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["lsof"]

[env]
PORT = "5000"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx expo start --web --port 8080 --localhost"
waitForPort = 8080

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 9876
externalPort = 3001

[[ports]]
localPort = 9877
externalPort = 3002

[userenv]

[userenv.shared]
FRONTEND_URL = "https://rawstock.live"
GOOGLE_CALLBACK_URL = "https://rawstock.live/api/auth/google-callback"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server_dist/index.js"]
build = ["npm", "run", "build:prod"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000


